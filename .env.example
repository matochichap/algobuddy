UI_PORT=3000
USER_SERVICE_PORT=3001
MATCHING_SERVICE_PORT=3002
QUESTION_SERVICE_PORT=3003
COLLABORATION_SERVICE_PORT=3004
API_GATEWAY_PORT=4000

UI_BASE_URL=http://localhost:3000 # change host to container name when running with docker
USER_SERVICE_BASE_URL=http://localhost:3001 # change host to container name when running with docker
MATCHING_SERVICE_BASE_URL=http://localhost:3002 # change host to container name when running with docker
QUESTION_SERVICE_BASE_URL=http://localhost:3003 # change host to container name when running with docker
COLLABORATION_SERVICE_BASE_URL=http://localhost:3004 # change host to container name when running with docker
API_GATEWAY_BASE_URL=http://localhost:4000
PISTON_API_BASE_URL=https://emkc.org

REDIS_HOST= # requires setup on redis cloud or using local docker instance(see ./db)
REDIS_PORT=
REDIS_USERNAME= # empty for docker setup
REDIS_PASSWORD= # empty for docker setup

USER_SERVICE_MONGODB_CONNECTION_STRING= # requires setup on mongo atlas or using local docker instance(see ./db)
QUESTION_SERVICE_MONGODB_CONNECTION_STRING=

JWT_ACCESS_SECRET= # random secure string for signing jwt access token

GOOGLE_CLIENT_ID= # requires setup on google cloud
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

# nextjs env variables for dev
NEXT_PUBLIC_USER_SERVICE_BASE_URL=http://localhost:4000
NEXT_PUBLIC_MATCHING_SERVICE_BASE_URL=http://localhost:4000
NEXT_PUBLIC_QUESTION_SERVICE_BASE_URL=http://localhost:4000
NEXT_PUBLIC_COLLABORATION_SERVICE_BASE_URL=http://localhost:4000
